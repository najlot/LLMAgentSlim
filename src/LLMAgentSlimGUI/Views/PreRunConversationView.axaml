<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LLMAgentSlimGUI.ViewModels"
             x:Class="LLMAgentSlimGUI.Views.PreRunConversationView"
             x:DataType="vm:PreRunConversationViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="18">
            <Border Classes="card alt" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Workspace setup"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Select a workspace, review llmagentslim.json, and choose the plugins this run can use."
                                   Opacity="0.82"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            VerticalAlignment="Top"
                            Content="Select workspace"
                            Command="{Binding PickWorkspaceCommand}"
                            CommandParameter="{Binding $parent[Window]}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.6*,1*"
                  ColumnSpacing="18">
                <Border Grid.Column="0" Classes="card" Padding="18">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Configuration"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ConfigurationSourceLabel}"
                                       Opacity="0.82"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBox Grid.Row="1"
                                 IsReadOnly="True"
                                 Text="{Binding WorkspacePath}"
                                 PlaceholderText="No workspace selected" />

                        <TextBox Grid.Row="2"
                                 AcceptsReturn="True"
                                 MinHeight="340"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Cascadia Mono, monospace"
                                 Text="{Binding ConfigurationText}" />

                        <Button Grid.Row="3"
                                HorizontalAlignment="Right"
                                Content="Save configuration"
                                Command="{Binding SaveConfigurationCommand}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="card alt" Padding="18">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Plugins"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Choose the toolset exposed to the agent for this run."
                                       Opacity="0.82"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      MaxHeight="480"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding AvailablePlugins}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="card"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                <CheckBox IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Top" />

                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   Text="{Binding DisplayName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold" />
                                                        <Border DockPanel.Dock="Right"
                                                                Classes="pill"
                                                                Padding="10,4"
                                                                Margin="12,0,0,0">
                                                            <TextBlock Text="{Binding Key}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                    </DockPanel>

                                                    <TextBlock Text="{Binding Description}"
                                                               Opacity="0.82"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Row="2"
                                HorizontalAlignment="Right"
                                Content="Save plugin selection"
                                Command="{Binding SavePluginSelectionCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Classes="card alt" Padding="18">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Initial request"
                                   FontSize="20"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Describe the task to run in the selected workspace."
                                   Opacity="0.82"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             AcceptsReturn="True"
                             MinHeight="160"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Text="{Binding RequestText}" />

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Text="The run button becomes available once a workspace is loaded and the request is not empty."
                                   VerticalAlignment="Center"
                                   Opacity="0.72"
                                   TextWrapping="Wrap" />

                        <Button Grid.Column="1"
                                MinWidth="140"
                                Content="Run"
                                Command="{Binding RunCommand}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
